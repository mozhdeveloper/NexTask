# Copy to .env.local and fill in your own Supabase project values.
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-public-key>
SUPABASE_SERVICE_ROLE_KEY=<service-role-secret>  # server-only, never expose
NEXT_PUBLIC_SUPABASE_STORAGE_BUCKET=submissions
NEXT_PUBLIC_SUPABASE_PROJECT_REF=<project-ref>

