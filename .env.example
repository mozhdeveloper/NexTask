# Copy to .env.local and fill in your values.
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-public-key>
SUPABASE_SERVICE_ROLE_KEY=<service-role-secret>  # server-only, never expose
NEXT_PUBLIC_SUPABASE_STORAGE_BUCKET=submissions
NEXT_PUBLIC_SUPABASE_PROJECT_REF=<project-ref>

# ── Email (Resend) ────────────────────────────────────────────────────
# Sign up at https://resend.com — free tier: 100 emails/day, 3 000/month.
# The key starts with "re_".
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx
# Verified sender address shown in the From field.
# During development you can leave this as-is; Resend's onboarding address
# only delivers to the Resend account owner's email (for test/dev use only).
# Before going to production, verify your own domain in the Resend dashboard
# and update this to: YourApp <noreply@yourdomain.com>
RESEND_FROM=NexTask <onboarding@resend.dev>

# ── Backup storage path ──────────────────────────────────────────────
# Directory where backup files are written. Relative paths are resolved
# from the project root. Update this to your deployment storage path.
BACKUP_STORAGE_PATH=./storage/backups

# ── Cron security ────────────────────────────────────────────────────
# Secret sent as "Authorization: Bearer <value>" by Vercel Cron to
# the /api/backups/auto endpoint. Generate a random string:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CRON_SECRET=change-me-to-a-random-secret

# ── Web Push (VAPID) ─────────────────────────────────────────────────
# Generate with: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=BDS2I26tT0cOwHP-bDyS42Y4TKrs63xu5OfbarlWSoW0rSmrubgw0dL9tZpLpghZwOQZAkyqRjKz2BtyyPHhw4g
VAPID_PRIVATE_KEY=MprSxrZeUCDn8pXyOYWU11JB00OfF-2K5CroJsruqmY
VAPID_SUBJECT=mailto:admin@nextask.local
